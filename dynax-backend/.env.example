# ─── Server ───────────────────────────────────────────────────────────────────
APP_ENV=development
APP_PORT=8080
APP_NAME=DynaX API
APP_VERSION=1.0.0

# ─── Supabase / Database ──────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgres://postgres:password@db.your-project.supabase.co:5432/postgres

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRY_HOURS=24
JWT_REFRESH_EXPIRY_HOURS=168

# ─── Redis (rate limiting & session store) ────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ─── Resend (email) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=noreply@dynalimb.com
RESEND_FROM_NAME=DynaX Platform

# ─── AI (OpenAI) ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o

# ─── Storage (Supabase Storage) ───────────────────────────────────────────────
STORAGE_BUCKET_DOCS=dynax-documents
STORAGE_BUCKET_DEVICES=dynax-devices
STORAGE_BUCKET_AVATARS=dynax-avatars

# ─── Security ─────────────────────────────────────────────────────────────────
BCRYPT_COST=12
RATE_LIMIT_RPS=10
RATE_LIMIT_BURST=20
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://dynax.dynalimb.com

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=debug
LOG_FORMAT=pretty
